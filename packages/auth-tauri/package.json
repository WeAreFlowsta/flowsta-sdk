{
  "name": "@flowsta/auth-tauri",
  "version": "0.1.0",
  "description": "Flowsta Auth plugin for Tauri v2 desktop apps using Flowsta Vault",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "flowsta",
    "tauri",
    "desktop",
    "vault",
    "identity",
    "holochain",
    "decentralized"
  ],
  "author": "Flowsta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WeAreFlowsta/flowsta-sdk.git",
    "directory": "packages/auth-tauri"
  },
  "peerDependencies": {
    "@tauri-apps/api": ">=2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
