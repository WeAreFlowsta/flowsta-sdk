{
  "name": "@flowsta/holochain",
  "version": "2.1.0",
  "description": "Flowsta Holochain SDK - Link your Holochain app's agent key with the user's Flowsta Vault identity.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "flowsta",
    "holochain",
    "agent-linking",
    "identity",
    "web3",
    "decentralized"
  ],
  "author": "Flowsta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WeAreFlowsta/flowsta-sdk.git",
    "directory": "packages/holochain"
  },
"devDependencies": {
    "happy-dom": "20.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "7.3.1",
    "vitest": "^4.0.18"
  }
}
